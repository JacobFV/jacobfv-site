{
  "name": "jacobfv-site",
  "version": "0.0.0",
  "private": true,
  "description": "Jacob Valdez's site — a navigable graph of projects, writing, and visions.",
  "scripts": {
    "predev": "velite build",
    "dev": "next dev",
    "prebuild": "velite build",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "velite build && tsc --noEmit",
    "migrate": "tsx scripts/migrate-jekyll.ts",
    "sync:assets": "tsx scripts/sync-assets.ts",
    "validate": "velite build && tsx scripts/validate-edges.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "framer-motion": "^11.0.0",
    "@xyflow/react": "^12.0.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/drei": "^10.0.0",
    "three": "^0.170.0",
    "d3-force": "^3.0.0",
    "lenis": "^1.1.0",
    "fuse.js": "^7.0.0",
    "citation-js": "^0.7.0",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0",
    "cmdk": "^1.0.0",
    "next-mdx-remote": "^5.0.0",
    "rehype-katex": "^7.0.0",
    "remark-math": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/d3-force": "^3.0.0",
    "@types/three": "^0.170.0",
    "typescript": "^5.6.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "velite": "^0.2.0",
    "tsx": "^4.19.0",
    "gray-matter": "^4.0.3",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
